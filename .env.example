# synaps-burnout — deploy-time auth configuration
# ------------------------------------------------------------------
# The image bakes NO credentials. You supply auth at `docker run` time.
# Copy this file to `.env`, uncomment ONE lane, fill it, then:
#
#     docker run --env-file .env -it --rm blackarch-synaps:bugbounty
#
# How Synaps chooses: if SYNAPS_AUTH_ENDPOINT is set it runs in BROKER mode
# (fetches short-lived tokens, stores nothing); otherwise it uses a local key
# from env below. Pick exactly one lane.
# ------------------------------------------------------------------

# ── Lane A — Anthropic API key (simplest: static, isolated, revocable) ──
#ANTHROPIC_API_KEY=sk-ant-...

# ── Lane B — OpenAI-compatible / local model (Ollama, vLLM, gateways) ──
# No credential leaves your network. Point at any /v1 endpoint.
#LOCAL_ENDPOINT=http://host.docker.internal:11434/v1
#LOCAL_API_KEY=placeholder        # many local servers ignore this; set anything

# ── Lane C — Credential broker (ZERO-CRED: container never holds a key) ──
# Container fetches short-lived tokens from a broker on your host/network.
# RECOMMENDED for offensive use — nothing to steal if the box gets popped.
#SYNAPS_AUTH_ENDPOINT=https://broker.your.host
#SYNAPS_MACHINE_TOKEN=...         # per-machine bearer presented to the broker
#SYNAPS_USER_ID=...

# ── Lane D — Bring-your-own config dir (advanced; mount, not just env) ──
# Mount your own Synaps base dir and point at it. YOU own the blast-radius call
# if that dir contains a primary OAuth auth.json.
#   docker run -v "$PWD/synaps-cfg:/cfg" -e SYNAPS_BASE_DIR=/cfg ...
#SYNAPS_BASE_DIR=/cfg
